# Supabase Configuration
# Get these values from: https://app.supabase.com/project/_/settings/api

# Your Supabase project URL (must start with https://)
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key
SUPABASE_ANON_KEY=your-anon-key-here

# IMPORTANT:
# - Never commit your actual .env file to version control
# - The .env file is already in .gitignore
# - Copy this file to .env and fill in your actual values
# - For Vercel: Add these as environment variables in your Vercel dashboard
# - For local development: Create a .env file with your values

# Alternative names (if using Vite or Create React App):
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key-here
